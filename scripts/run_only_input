#!/usr/bin/env bash
#
# Local regression *run* helper for OPALX.
#
# Runs one regression test input by executing <test>.local.
# It does NOT validate against reference, compare results, or generate HTML reports.
#

set -o errexit
set -o pipefail

declare -ri EC_ARG_ERROR=1
declare -ri EC_RUNTIME_ERROR=20

declare -r today="$(date +%Y-%m-%d)"
declare -r time="$(date +%H-%M)"
declare -r timestamp="${today}_${time}"

die() {
  (( $1 > 0 )) && exec 1>&2
  echo -e "$2\n"
  exit "$1"
}

usage() {
  cat 1>&2 <<'EOF'
Usage:
  run_only_input --build <path/to/build> --input <path/to/RegressionTests> [<name of test>]

Runs regression test(s) by executing <test>.local only.
No reference validation, comparison, or report generation is performed.

Required:
  --build <dir>   Build directory containing OPALX executable at <dir>/src/opalx
  --input <dir>   RegressionTests directory (or regression-tests-x repo root)

Optional:
  <name of test>  If provided, run only that test (subfolder name under RegressionTests)

Output:
  Writes under NightlyBuildX/runs/<testName>/<timestamp>/ (or runs/all/<timestamp>/).
EOF
  exit ${EC_ARG_ERROR}
}

# Get absolute path to this script (macOS/Linux portable)
if [[ "$(uname)" == "Darwin" ]]; then
  declare -r abs_scriptname="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "$0")"
else
  declare -r abs_scriptname="$(readlink -f "$0")"
fi

declare -r bindir="${abs_scriptname%/*}"
declare -r nightlybuildx_dir="${bindir%/*}"

declare -r run_root="${nightlybuildx_dir}/runs"
declare build_dir=""
declare input_dir=""
declare test_name=""

while (( $# > 0 )); do
  case "$1" in
    --build|--build=* )
      if [[ "$1" == *=* ]]; then
        build_dir="${1#*=}"
      else
        build_dir="${2:-}"; shift 1
      fi
      ;;
    --input|--input=* )
      if [[ "$1" == *=* ]]; then
        input_dir="${1#*=}"
      else
        input_dir="${2:-}"; shift 1
      fi
      ;;
    -h|-\?|--help )
      usage
      ;;
    -* )
      die ${EC_ARG_ERROR} "Unknown option: $1\n\n$(usage)"
      ;;
    * )
      # Only support at most one test name (per requested interface).
      if [[ -n "${test_name}" ]]; then
        die ${EC_ARG_ERROR} "Only one <name of test> is supported. Got: '${test_name}' and '$1'"
      fi
      test_name="$1"
      ;;
  esac
  shift 1
done

[[ -n "${build_dir}" ]] || usage
[[ -n "${input_dir}" ]] || usage

build_dir="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "${build_dir}")"
[[ -d "${build_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --build is not a directory: ${build_dir}"

input_dir="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "${input_dir}")"
[[ -d "${input_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --input is not a directory: ${input_dir}"

# If a nested RegressionTests directory exists, prefer it.
if [[ -d "${input_dir}/RegressionTests" ]]; then
  input_dir="${input_dir}/RegressionTests"
fi

[[ -d "${input_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: RegressionTests directory not found under: ${input_dir}"

declare -r opalx_exe="${build_dir}/src/opalx"
[[ -f "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable not found at: ${opalx_exe}"
[[ -x "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable is not executable: ${opalx_exe}"

in_array() {
  local value="$1"
  shift
  local x
  for x in "$@"; do
    if [[ "${x}" == "${value}" ]]; then
      return 0
    fi
  done
  return 1
}

is_runnable_test() {
  local tname="$1"
  local tdir="${input_dir}/${tname}"
  [[ -d "${tdir}" ]] || return 1
  [[ ! -f "${tdir}/disabled" ]] || return 1
  [[ -f "${tdir}/${tname}.in" ]] || return 1
  [[ -f "${tdir}/${tname}.local" ]] || return 1
  return 0
}

declare -a tests=()
if [[ -n "${test_name}" ]]; then
  is_runnable_test "${test_name}" || die ${EC_ARG_ERROR} "ERROR: unknown or non-runnable test: ${test_name}"
  tests=( "${test_name}" )
else
  # Discover runnable tests under input_dir.
  for d in "${input_dir}"/*; do
    [[ -d "${d}" ]] || continue
    tname="$(basename "${d}")"
    [[ "${tname}" == .* ]] && continue
    is_runnable_test "${tname}" && tests+=( "${tname}" )
  done

  # Sort for stable output.
  declare -a tests_sorted=()
  while IFS= read -r line; do
    [[ -n "${line}" ]] && tests_sorted+=( "${line}" )
  done < <(printf '%s\n' "${tests[@]}" | sort)
  tests=( "${tests_sorted[@]}" )
fi

if [[ "${#tests[@]}" -eq 0 ]]; then
  die ${EC_ARG_ERROR} "No runnable tests found under: ${input_dir}"
fi

declare run_dir=""
if [[ -n "${test_name}" ]]; then
  run_dir="${run_root}/${test_name}/${timestamp}"
else
  run_dir="${run_root}/all/${timestamp}"
fi

declare run_logs_dir="${run_dir}/logs"
declare run_work_root="${run_dir}/work"

mkdir -p "${run_logs_dir}" "${run_work_root}"

echo "Running OPALX regression test(s) (no compare/report)"
echo "Build: ${build_dir}"
echo "Input: ${input_dir}"
echo "Tests: ${tests[*]}"
echo "Run dir: ${run_dir}"

export OPALX_EXE_PATH="$(dirname "${opalx_exe}")"

overall_exit=0

for t in "${tests[@]}"; do
  work_dir="${run_work_root}/${t}"

  # Fresh work dir per test.
  rm -rf "${work_dir}"
  mkdir -p "${work_dir}"
  cp -a "${input_dir}/${t}/." "${work_dir}/"

  # Capture baseline file names at root for staging after the run.
  declare -a baseline_files=()
  for p in "${work_dir}"/*; do
    [[ -f "${p}" ]] || continue
    baseline_files+=( "$(basename "${p}")" )
  done

  keep_names=(
    "${t}.in"
    "${t}.rt"
    "${t}.local"
    "${t}.sge"
    "disabled"
  )

  log_file="${run_logs_dir}/${t}.out"
  echo "---- ${t} ----"

  # Run the input only.
  set +e
  {
    cd "${work_dir}"
    # Use bash to avoid relying on executable bit.
    bash "./${t}.local" > "${log_file}" 2>&1
  }
  exit_code=$?
  set -e

  # Best-effort staging: move only newly generated root-level artifacts into data/.
  data_dir="${work_dir}/data"
  mkdir -p "${data_dir}"

  for p in "${work_dir}"/*; do
    [[ -f "${p}" ]] || continue
    name="$(basename "${p}")"
    [[ "${name}" == .* ]] && continue

    if in_array "${name}" "${keep_names[@]}"; then
      continue
    fi
    if in_array "${name}" "${baseline_files[@]}"; then
      continue
    fi

    # Stage new output file.
    mv "${p}" "${data_dir}/${name}" 2>/dev/null || true
  done

  if (( exit_code != 0 )); then
    echo "WARN: ${t} exited with code ${exit_code} (see ${log_file})"
    overall_exit="${exit_code}"
  fi
done

if (( overall_exit != 0 )); then
  die ${EC_RUNTIME_ERROR} "ERROR: one or more tests failed. Outputs in: ${run_dir}"
fi

echo "Done. Outputs in: ${run_dir}"

