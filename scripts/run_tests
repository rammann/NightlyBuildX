#!/usr/bin/env bash

set -o errexit
set -o pipefail

declare -ri EC_ARG_ERROR=1
declare -ri EC_RUNTIME_ERROR=20

declare timestamp_override=""

die() {
  (( $1 > 0 )) && exec 1>&2
  echo -e "$2\n"
  exit "$1"
}

usage() {
  cat 1>&2 <<'EOF'
Usage:
  run_tests --build <path/to/build> --tests <path/to/RegressionTests> [--unittests on|off] [--remote] [--] [test1 test2 ...]

Runs OPALX unit + regression test execution only (no report generation).

Required:
  --build <dir>   Build directory containing OPALX executable at <dir>/src/opalx
  --tests <dir>   Regression tests root or RegressionTests directory

Options:
  --unittests on|off   Run or skip unit tests (default: on)
  --remote             Save run under runs_remote/<timestamp>/ instead of runs/<timestamp>/

Internal:
  --timestamp <value>  Fixed timestamp (used by run_tests_report chaining)
EOF
  exit ${EC_ARG_ERROR}
}

abspath() {
  python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "$1"
}

if [[ "$(uname)" == "Darwin" ]]; then
  declare -r abs_scriptname="$(abspath "$0")"
else
  declare -r abs_scriptname="$(readlink -f "$0")"
fi

declare -r bindir="${abs_scriptname%/*}"
declare -r nightlybuildx_dir="${bindir%/*}"
declare -r report_root="${nightlybuildx_dir}/report"
declare -r runs_root="${nightlybuildx_dir}/runs"
declare -r runs_remote_root="${nightlybuildx_dir}/runs_remote"

declare build_dir=""
declare tests_dir=""
declare do_unittests=on
declare run_subdir="runs"
declare -a tests=()

while (( $# > 0 )); do
  case "$1" in
    --build|--build=* )
      if [[ "$1" == *=* ]]; then
        build_dir="${1#*=}"
      else
        build_dir="${2:-}"; shift 1
      fi
      ;;
    --tests|--tests-dir|--tests=*|--tests-dir=* )
      if [[ "$1" == *=* ]]; then
        tests_dir="${1#*=}"
      else
        tests_dir="${2:-}"; shift 1
      fi
      ;;
    --unittests|--unittests=* )
      ut_val=""
      if [[ "$1" == *=* ]]; then
        ut_val="${1#*=}"
      else
        ut_val="${2:-}"; shift 1
      fi
      case "$(printf '%s' "${ut_val}" | tr '[:upper:]' '[:lower:]')" in
        on ) do_unittests=on ;;
        off ) do_unittests=off ;;
        * ) die ${EC_ARG_ERROR} "ERROR: --unittests must be on or off, got: ${ut_val}" ;;
      esac
      ;;
    --remote )
      run_subdir="runs_remote"
      ;;
    --timestamp|--timestamp=* )
      if [[ "$1" == *=* ]]; then
        timestamp_override="${1#*=}"
      else
        timestamp_override="${2:-}"; shift 1
      fi
      ;;
    -h|-\?|--help )
      usage
      ;;
    -- )
      shift 1
      while (( $# > 0 )); do
        tests+=( "$1" )
        shift 1
      done
      break
      ;;
    -* )
      die ${EC_ARG_ERROR} "Unknown option: $1"
      ;;
    * )
      tests+=( "$1" )
      ;;
  esac
  shift 1
done

[[ -n "${build_dir}" ]] || usage
[[ -n "${tests_dir}" ]] || usage
build_dir="$(abspath "${build_dir}")"
tests_dir="$(abspath "${tests_dir}")"
[[ -d "${build_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --build is not a directory: ${build_dir}"
[[ -d "${tests_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --tests is not a directory: ${tests_dir}"

if [[ -d "${tests_dir}/RegressionTests" ]]; then
  tests_dir="${tests_dir}/RegressionTests"
fi

declare -r opalx_exe="${build_dir}/src/opalx"
[[ -f "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable not found at: ${opalx_exe}"
[[ -x "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable is not executable: ${opalx_exe}"

declare run_parent="${runs_root}"
if [[ "${run_subdir}" == "runs_remote" ]]; then
  run_parent="${runs_remote_root}"
fi
declare -r timestamp="${timestamp_override:-$(date +%Y-%m-%d_%H-%M-%S)}"
declare -r run_dir="${run_parent}/${timestamp}"
declare -r run_logs_dir="${run_dir}/logs"
declare -r run_raw_dir="${run_dir}/raw"
declare -r unit_log_file="${run_logs_dir}/unit-tests.out"
declare -r unit_summary_file="${run_dir}/unit-tests-summary.json"
declare -r run_meta_file="${run_dir}/run-meta.json"

mkdir -p "${report_root}" "${run_logs_dir}" "${run_raw_dir}"

_fmt_init() {
  if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    _B=$'\033[1m'
    _D=$'\033[2m'
    _C=$'\033[36m'
    _G=$'\033[32m'
    _Y=$'\033[33m'
    _R=$'\033[31m'
    _M=$'\033[35m'
    _X=$'\033[0m'
  else
    _B='' _D='' _C='' _G='' _Y='' _R='' _M='' _X=''
  fi
}

main() {
  local reg_exit=0
  local unit_exit=0
  _fmt_init

  echo ""
  echo "${_D}────────────────────────────────────────────────────────${_X}"
  echo "${_B}${_C}OPALX regression${_X} ${_D}· execution only (raw data)${_X}"
  echo "${_D}────────────────────────────────────────────────────────${_X}"
  echo ""
  printf '  %sBuild%s      %s%s%s\n' "${_B}" "${_X}" "${_D}" "${build_dir}" "${_X}"
  printf '  %sTests%s      %s%s%s\n' "${_B}" "${_X}" "${_D}" "${tests_dir}" "${_X}"
  printf '  %sUnit tests%s  %s%s%s\n' "${_B}" "${_X}" "${_D}" "${do_unittests}" "${_X}"
  printf '  %sMode%s       %s%s%s\n' "${_B}" "${_X}" "${_D}" "${run_subdir}" "${_X}"
  printf '  %sRaw run dir%s %s%s%s\n' "${_B}" "${_X}" "${_M}" "${run_dir}" "${_X}"
  echo ""

  local -r runner="${bindir}/run-reg-tests.py"

  if [[ "${do_unittests}" == "on" ]]; then
    echo "${_B}${_Y}▶ Unit tests${_X} ${_D}(ctest -L unit)${_X}"
    echo "  ${_D}${build_dir}${_X}"
    echo ""
    {
      echo "# ctest -L unit"
      echo "# started_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      ( cd "${build_dir}" && ctest -L unit )
    } > "${unit_log_file}" 2>&1 || unit_exit=$?

    python3 - "$unit_log_file" "$unit_exit" "$unit_summary_file" <<'PY'
import json
import re
import sys

log_path = sys.argv[1]
unit_exit = int(sys.argv[2])
out_path = sys.argv[3]

try:
    with open(log_path, "r", encoding="utf-8", errors="replace") as f:
        content = f.read()
except OSError:
    content = ""

total = 0
failed = 0
m = re.search(r"(\d+)\s+tests?\s+failed\s+out\s+of\s+(\d+)", content, re.IGNORECASE)
if m:
    failed = int(m.group(1))
    total = int(m.group(2))
else:
    m = re.search(r"(\d+)%\s+tests?\s+passed,\s+(\d+)\s+tests?\s+failed\s+out\s+of\s+(\d+)", content, re.IGNORECASE)
    if m:
        failed = int(m.group(2))
        total = int(m.group(3))
passed = max(total - failed, 0)
state = "passed" if (unit_exit == 0 and failed == 0) else "failed"
if total == 0 and unit_exit == 0:
    state = "passed"
payload = {"state": state, "total": total, "passed": passed, "failed": failed, "log_relpath": "logs/unit-tests.out"}
with open(out_path, "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=False)
PY
    if (( unit_exit != 0 )); then
      echo "${_R}Unit tests failed (exit=${unit_exit}); continuing with regression tests.${_X}"
      echo ""
    fi
  else
    echo "${_D}Unit tests skipped (--unittests off).${_X}"
    echo ""
    {
      echo "# Unit tests skipped (--unittests off)"
      echo "# skipped_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    } > "${unit_log_file}"
    python3 - "$unit_summary_file" <<'PY'
import json
import sys
payload = {"state": "skipped", "total": 0, "passed": 0, "failed": 0, "log_relpath": "logs/unit-tests.out"}
with open(sys.argv[1], "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=False)
PY
  fi

  local -a opts=()
  opts+=( "--base-dir=${tests_dir}" )
  opts+=( "--publish-dir=${run_dir}" )
  opts+=( "--build-dir=${build_dir}" )
  opts+=( "--opalx-exe=${opalx_exe}" )
  opts+=( "--timestamp=${timestamp}" )
  opts+=( "--execution-only" )
  opts+=( "--raw-data-dir=${run_raw_dir}" )
  opts+=( "--unit-tests-summary=${unit_summary_file}" )

  python3 "${runner}" "${opts[@]}" -- "${tests[@]}" || reg_exit=$?

  python3 - "$run_meta_file" "$timestamp" "$build_dir" "$tests_dir" "$opalx_exe" "$run_subdir" "${tests[@]}" <<'PY'
import json
import os
import sys

meta_path = sys.argv[1]
timestamp = sys.argv[2]
build_dir = sys.argv[3]
tests_dir = sys.argv[4]
opalx_exe = sys.argv[5]
run_mode = sys.argv[6]
tests = sys.argv[7:]

def parse_cache(cache_path):
    info = {"Build Type": "-", "Kokkos Architecture": "-", "Device": "CPU", "Compiler": "-"}
    if not os.path.isfile(cache_path):
        return info
    cache = {}
    with open(cache_path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("//") or line.startswith("#") or ":" not in line or "=" not in line:
                continue
            key_type, value = line.split("=", 1)
            key, _ = key_type.split(":", 1)
            cache[key] = value
    info["Build Type"] = cache.get("CMAKE_BUILD_TYPE") or "-"
    arch = sorted(k.replace("Kokkos_ARCH_", "") for k, v in cache.items() if k.startswith("Kokkos_ARCH_") and str(v).upper() in {"ON", "TRUE", "1"})
    info["Kokkos Architecture"] = ", ".join(arch) if arch else "-"
    cuda = str(cache.get("Kokkos_ENABLE_CUDA", "OFF")).upper() in {"ON", "TRUE", "1"}
    hip = str(cache.get("Kokkos_ENABLE_HIP", "OFF")).upper() in {"ON", "TRUE", "1"}
    info["Device"] = "GPU" if (cuda or hip) else "CPU"
    info["Compiler"] = cache.get("CMAKE_CXX_COMPILER") or cache.get("CMAKE_C_COMPILER") or "-"
    return info

payload = {
    "timestamp": timestamp,
    "run_mode": run_mode,
    "build_dir": build_dir,
    "tests_dir": tests_dir,
    "opalx_exe": opalx_exe,
    "selected_tests": tests,
    "build_info": parse_cache(os.path.join(build_dir, "CMakeCache.txt")),
}
with open(meta_path, "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=False)
PY

  if (( unit_exit != 0 || reg_exit != 0 )); then
    die ${EC_RUNTIME_ERROR} "ERROR: tests failed (unit_exit=${unit_exit}, regression_exit=${reg_exit})"
  fi

  echo ""
  echo "${_G}${_B}Done.${_X} Raw data: ${_M}${run_dir}${_X}"
  echo ""
}

main
