#!/usr/bin/env bash

#
# Local regression test runner for OPALX.
#
# Contract:
# - You build OPALX yourself (this script never compiles).
# - You provide the regression tests directory (this script does not clone/pull).
# - This script runs regression tests using the provided build, produces matplotlib
#   plots for .rt-defined stat quantities, and generates a modern HTML report.
#

set -o errexit
set -o pipefail

declare -ri EC_ARG_ERROR=1
declare -ri EC_RUNTIME_ERROR=20

declare -r today="$(date +%Y-%m-%d)"
declare -r time="$(date +%H-%M)"
declare -r timestamp="${today}_${time}"

die() {
  (( $1 > 0 )) && exec 1>&2
  echo -e "$2\n"
  exit "$1"
}

usage() {
  cat 1>&2 <<'EOF'
Usage:
  run_tests --build <path/to/build> --tests <path/to/RegressionTests> [--] [test1 test2 ...]

Runs OPALX regression tests using an existing build.

What it does:
  1) Runs all regression tests in the given tests folder (or a subset if test names are provided)
  2) Generates matplotlib plots (reference vs generated + difference) for .rt stat quantities
  3) Writes a static HTML report under NightlyBuildX/report/

Required:
  --build <dir>   Build directory containing the OPALX executable at <dir>/src/opalx
  --tests <dir>   Directory containing regression test subfolders (e.g. .../RegressionTests)

Notes:
  - Any args after -- are treated as regression test names to run.
EOF
  exit ${EC_ARG_ERROR}
}

# Get absolute path to this script (macOS/Linux portable)
if [[ "$(uname)" == "Darwin" ]]; then
  declare -r abs_scriptname="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "$0")"
else
  declare -r abs_scriptname="$(readlink -f "$0")"
fi

declare -r bindir="${abs_scriptname%/*}"
declare -r nightlybuildx_dir="${bindir%/*}"

declare -r report_root="${nightlybuildx_dir}/report"
declare -r run_dir="${report_root}/runs/${timestamp}"
declare -r run_logs_dir="${run_dir}/logs"
declare -r run_plots_dir="${run_dir}/plots"

declare build_dir=""
declare tests_dir=""
declare -a tests=()

while (( $# > 0 )); do
  case "$1" in
    --build|--build=* )
      if [[ "$1" == *=* ]]; then
        build_dir="${1#*=}"
      else
        build_dir="${2:-}"; shift 1
      fi
      ;;
    --tests|--tests-dir|--tests=*|--tests-dir=* )
      if [[ "$1" == *=* ]]; then
        tests_dir="${1#*=}"
      else
        tests_dir="${2:-}"; shift 1
      fi
      ;;
    -h|-\?|--help )
      usage
      ;;
    -- )
      shift 1
      while (( $# > 0 )); do
        tests+=( "$1" )
        shift 1
      done
      break
      ;;
    -* )
      die ${EC_ARG_ERROR} "Unknown option: $1\n\n$(usage)"
      ;;
    * )
      # Allow passing tests without "--" too
      tests+=( "$1" )
      ;;
  esac
  shift 1
done

[[ -n "${build_dir}" ]] || usage
[[ -n "${tests_dir}" ]] || usage
build_dir="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "${build_dir}")"
[[ -d "${build_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --build is not a directory: ${build_dir}"
tests_dir="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "${tests_dir}")"
[[ -d "${tests_dir}" ]] || die ${EC_ARG_ERROR} "ERROR: --tests is not a directory: ${tests_dir}"

# Accept either a direct RegressionTests dir or a regression-tests-x repo root.
# If a nested RegressionTests directory exists, prefer it.
if [[ -d "${tests_dir}/RegressionTests" ]]; then
  tests_dir="${tests_dir}/RegressionTests"
fi

declare -r opalx_exe="${build_dir}/src/opalx"
[[ -f "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable not found at: ${opalx_exe}"
[[ -x "${opalx_exe}" ]] || die ${EC_ARG_ERROR} "ERROR: OPALX executable is not executable: ${opalx_exe}"

mkdir -p "${report_root}" "${run_logs_dir}" "${run_plots_dir}"

main() {
  echo "Running regression tests using build: ${build_dir}"
  echo "Using regression tests directory: ${tests_dir}"
  echo "Writing report to: ${run_dir}"

  local -r runner="${bindir}/run-reg-tests.py"

  local -a opts=()
  opts+=( "--base-dir=${tests_dir}" )
  opts+=( "--publish-dir=${run_dir}" )
  opts+=( "--plots-dir=${run_plots_dir}" )
  opts+=( "--logs-dir=${run_logs_dir}" )
  opts+=( "--build-dir=${build_dir}" )
  opts+=( "--opalx-exe=${opalx_exe}" )
  opts+=( "--timestamp=${timestamp}" )

  python3 "${runner}" "${opts[@]}" -- "${tests[@]}" || die ${EC_RUNTIME_ERROR} "ERROR: regression tests failed"

  echo "Done. Open ${report_root}/index.html"
}

main
