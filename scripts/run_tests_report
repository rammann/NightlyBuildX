#!/usr/bin/env bash

#
# Local shortcut: run tests, then build report.
#

set -o errexit
set -o pipefail

declare -ri EC_ARG_ERROR=1
declare -ri EC_RUNTIME_ERROR=20


die() {
  (( $1 > 0 )) && exec 1>&2
  echo -e "$2\n"
  exit "$1"
}

usage() {
  cat 1>&2 <<'EOF'
Usage:
  run_tests_report --build <path/to/build> --tests <path/to/RegressionTests> [--unittests on|off] [--] [test1 test2 ...]

Runs run_tests + build_report for the same local timestamp.

What it does:
  1) Calls run_tests (local mode only) to generate outputs + results.json
  2) Calls build_report --run <same timestamp> to generate HTML report pages

Required:
  --build <dir>   Build directory containing the OPALX executable at <dir>/src/opalx
  --tests <dir>   Directory containing regression test subfolders (e.g. .../RegressionTests)

Options:
  --unittests on|off   Run or skip unit tests (default: on).
Notes:
  - --remote is not allowed in run_tests_report (local-only shortcut).
  - Any args after -- are treated as regression test names to run.
EOF
  exit ${EC_ARG_ERROR}
}

# Get absolute path to this script (macOS/Linux portable)
if [[ "$(uname)" == "Darwin" ]]; then
  declare -r abs_scriptname="$(python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "$0")"
else
  declare -r abs_scriptname="$(readlink -f "$0")"
fi

declare -r bindir="${abs_scriptname%/*}"
declare -r nightlybuildx_dir="${bindir%/*}"

declare -r report_root="${nightlybuildx_dir}/report"

declare build_dir=""
declare tests_dir=""
declare do_unittests=on
declare -a tests=()

while (( $# > 0 )); do
  case "$1" in
    --build|--build=* )
      if [[ "$1" == *=* ]]; then
        build_dir="${1#*=}"
      else
        build_dir="${2:-}"; shift 1
      fi
      ;;
    --tests|--tests-dir|--tests=*|--tests-dir=* )
      if [[ "$1" == *=* ]]; then
        tests_dir="${1#*=}"
      else
        tests_dir="${2:-}"; shift 1
      fi
      ;;
    --unittests|--unittests=* )
      ut_val=""
      if [[ "$1" == *=* ]]; then
        ut_val="${1#*=}"
      else
        ut_val="${2:-}"; shift 1
      fi
      case "$(printf '%s' "${ut_val}" | tr '[:upper:]' '[:lower:]')" in
        on ) do_unittests=on ;;
        off ) do_unittests=off ;;
        * ) die ${EC_ARG_ERROR} "ERROR: --unittests must be on or off, got: ${ut_val}" ;;
      esac
      ;;
    --remote )
      die ${EC_ARG_ERROR} "ERROR: run_tests_report is local-only. Use run_tests --remote on clusters."
      ;;
    -h|-\?|--help )
      usage
      ;;
    -- )
      shift 1
      while (( $# > 0 )); do
        tests+=( "$1" )
        shift 1
      done
      break
      ;;
    -* )
      die ${EC_ARG_ERROR} "Unknown option: $1\n\n$(usage)"
      ;;
    * )
      # Allow passing tests without "--" too
      tests+=( "$1" )
      ;;
  esac
  shift 1
done

[[ -n "${build_dir}" ]] || usage
[[ -n "${tests_dir}" ]] || usage
declare -r timestamp="$(date +%Y-%m-%d_%H-%M-%S)"

_fmt_init() {
  if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    _B=$'\033[1m'
    _D=$'\033[2m'
    _C=$'\033[36m'
    _G=$'\033[32m'
    _Y=$'\033[33m'
    _R=$'\033[31m'
    _M=$'\033[35m'
    _X=$'\033[0m'
  else
    _B='' _D='' _C='' _G='' _Y='' _R='' _M='' _X=''
  fi
}

main() {
  _fmt_init

  echo ""
  echo "${_D}────────────────────────────────────────────────────────${_X}"
  echo "${_B}${_C}OPALX regression${_X} ${_D}· local shortcut (run + report)${_X}"
  echo "${_D}────────────────────────────────────────────────────────${_X}"
  echo ""
  printf '  %sBuild%s      %s%s%s\n' "${_B}" "${_X}" "${_D}" "${build_dir}" "${_X}"
  printf '  %sTests%s      %s%s%s\n' "${_B}" "${_X}" "${_D}" "${tests_dir}" "${_X}"
  printf '  %sUnit tests%s  %s%s%s\n' "${_B}" "${_X}" "${_D}" "${do_unittests}" "${_X}"
  printf '  %sTimestamp%s  %s%s%s\n' "${_B}" "${_X}" "${_M}" "${timestamp}" "${_X}"
  echo ""

  local -a run_cmd=()
  run_cmd+=( "${bindir}/run_tests" )
  run_cmd+=( "--build=${build_dir}" )
  run_cmd+=( "--tests=${tests_dir}" )
  run_cmd+=( "--unittests=${do_unittests}" )
  run_cmd+=( "--timestamp=${timestamp}" )
  run_cmd+=( "--" )
  run_cmd+=( "${tests[@]}" )
  "${run_cmd[@]}"

  echo "${_B}${_Y}▶ Build report${_X}"
  python3 "${bindir}/build_report" --run "${timestamp}"

  echo ""
  echo "${_G}${_B}Done.${_X} Open ${_M}${report_root}/index.html${_X}"
  echo ""
}

main
